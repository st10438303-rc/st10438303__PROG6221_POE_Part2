<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" 
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header com ASCII Art -->
        <Border Grid.Row="0" Background="#0f3460" Padding="20">
            <StackPanel>
                <TextBlock Text="🛡️ CYBERSECURITY AWARENESS BOT 🛡️" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#4ECDC4"
                           HorizontalAlignment="Center"
                           FontFamily="Consolas"/>
                <TextBlock Text="Your Personal Security Assistant" 
                           FontSize="11" 
                           Foreground="#ccc"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Chat Messages Area -->
        <ScrollViewer Grid.Row="2" 
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      Background="#1a1a2e">
            <ItemsControl x:Name="MessagesItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10,5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#16213e"/>
                                    <Setter Property="CornerRadius" Value="10"/>
                                    <Setter Property="Padding" Value="15,10"/>
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter Property="Background" Value="#0f3460"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Sender}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#4ECDC4"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="Foreground" Value="#FFE66D"/>
                                                    <Setter Property="Text" Value="You"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Message}" 
                                           Foreground="White" 
                                           TextWrapping="Wrap"
                                           FontSize="13"/>
                                <TextBlock Text="{Binding DisplayTime}" 
                                           Foreground="Gray" 
                                           FontSize="9"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input Area -->
        <Border Grid.Row="3" Background="#0f3460" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageTextBox" 
                         Grid.Column="0"
                         Height="40"
                         FontSize="14"
                         Padding="10,0"
                         Background="#1a1a2e"
                         Foreground="White"
                         BorderBrush="#4ECDC4"
                         BorderThickness="1"
                         KeyDown="MessageTextBox_KeyDown"/>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="📤 Send"
                        Width="80"
                        Height="40"
                        Margin="10,0,0,0"
                        Background="#4ECDC4"
                        Foreground="#1a1a2e"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>